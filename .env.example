# Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase SERVICE ROLE key (Project Settings > API > service_role).
# This key bypasses Row-Level Security — keep it server-side only,
# never commit it, never expose it to a browser/client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase URL + anon key, used by src/lib/supabaseBrowser.ts.
# Safe to expose to the browser — RLS (app.current_org_id) enforces
# tenant isolation for requests made with the anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API key for the Ruflo agent swarm (Phase 6). Server-only — like
# SUPABASE_SERVICE_ROLE_KEY, this must never reach the browser bundle.
ANTHROPIC_API_KEY=
